{
  "appId": "com.proxyvpn.wireguard",
  "appName": "GhostTunnel",
  "webDir": "dist",
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0d0d12",
      "androidSplashResourceName": "ghost_splash",
      "showSpinner": false
    }
  },
  "server": {
    "androidScheme": "https"
  }
}
