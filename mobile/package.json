{
  "name": "ghost-tunnel-mobile",
  "version": "1.1.0",
  "description": "GhostTunnel — Android VPN client",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:plugin": "npm run build --prefix plugins/capacitor-wireguard",
    "build": "npm run build:plugin && vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "cap:open": "cap open android",
    "build:apk": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "capacitor-wireguard": "file:./plugins/capacitor-wireguard"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
