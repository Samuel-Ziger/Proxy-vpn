{
  "name": "wireguard-vpn-mobile",
  "version": "1.0.0",
  "description": "WireGuard VPN Manager Mobile App",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:build": "cap build android",
    "cap:open": "cap open android",
    "cap:run": "cap run android",
    "build:apk": "npm run build && npm run cap:sync && npm run cap:build -- --keystorePath=./android.keystore --keystoreAlias=wireguard --keystoreAliasPassword=wireguard --keystorePassword=wireguard",
    "build:debug": "npm run build && npm run cap:sync && cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/platform": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "qrcodejs": "^1.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
